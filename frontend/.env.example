# ────────────────────────────────────────────────────────────────
# ToolSnapy Frontend Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ─── API Configuration ──────────────────────────────────────────
# Backend API URL (leave empty to use Vite proxy in development)
# For production, set to your backend URL: https://api.toolsnapy.com
VITE_API_URL=

# ─── Feature Flags ──────────────────────────────────────────────
# Enable/disable ads display (set to "true" when ads are ready)
VITE_ENABLE_ADS=false

# ─── Analytics (Optional) ───────────────────────────────────────
# Google Analytics measurement ID (leave empty to disable)
VITE_GA_MEASUREMENT_ID=

# ─── App Settings ───────────────────────────────────────────────
# App name displayed in UI
VITE_APP_NAME=ToolSnapy

# Contact email
VITE_CONTACT_EMAIL=support@toolsnapy.com
