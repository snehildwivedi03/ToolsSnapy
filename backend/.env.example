# ────────────────────────────────────────────────────────────────
# ToolSnapy Backend Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ─── Server Configuration ───────────────────────────────────────
# Port the Express server listens on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ─── CORS Configuration ─────────────────────────────────────────
# Frontend origin for CORS (use * for development, specific URL for production)
# Example: https://toolsnapy.com
CLIENT_ORIGIN=*

# ─── Security ───────────────────────────────────────────────────
# Rate limiting: max requests per window (default: 100)
RATE_LIMIT_MAX=100

# Rate limiting: window size in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ─── File Upload Settings ───────────────────────────────────────
# Maximum file size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# Uploads directory path (relative to backend root)
UPLOADS_DIR=uploads

# ─── Share Feature Settings ─────────────────────────────────────
# Share code expiry time in milliseconds (default: 15 minutes)
SHARE_EXPIRY_MS=900000

# Cleanup cycle interval in milliseconds (default: 6 hours)
# The cleanup service sweeps for expired shares on this interval
CLEANUP_INTERVAL_MS=21600000
