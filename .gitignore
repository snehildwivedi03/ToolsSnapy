# ────────────────────────────────────────────────────────────────
# ToolSnapy Root .gitignore
# ────────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build outputs
dist/
build/

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / Editor
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Uploaded files (share feature temp storage)
uploads/
